{
  "name": "mcp-dev-latam",
  "version": "0.2.0",
  "private": true,
  "description": "MCP servers for Latin American commerce — Brazil, Mexico, Argentina, Colombia",
  "workspaces": [
    "packages/payments/*",
    "packages/identity/*",
    "packages/fiscal/*",
    "packages/communication/*",
    "packages/ecommerce/*",
    "packages/banking/*",
    "packages/erp/*",
    "packages/crypto/*",
    "packages/mexico/*",
    "packages/argentina/*",
    "packages/colombia/*",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "audit:catalog": "python3 scripts/audit-catalog.py",
    "audit:catalog:json": "python3 scripts/audit-catalog.py --json",
    "audit:catalog:write": "python3 scripts/audit-catalog.py --out docs/catalog-audit.md"
  },
  "devDependencies": {
    "vitest": "^3.1.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/mcp-dev-latam"
  }
}
